set matchit
set surround
set clipboard=unnamedplus
set incsearch
set ignorecase
set scrolloff=5
set ideajoin

let mapleader = "\<Space>"

" ** 1. Navigations **
" files ('f'ile)
nmap <leader>fr <Action>(RecentFiles)
nmap <leader>fb <Action>(FileStructurePopup)

" code jump ('g'o)
nmap gd <Action>(GotoDeclaration)
nmap K <Action>(QuickDocumentation)
nmap <leader>gi <Action>(GotoImplementation)
nmap <leader>gu <Action>(ShowUsages)
nmap <leader>gb <Action>(Back)
nmap <leader>gf <Action>(Forward)

" errors ('e'rror)
nmap <leader>en <Action>(NextError)
nmap <leader>ep <Action>(PreviousError)


" ** 2. Code refactorings **
" refactor ('r'efactor)
nmap <leader>rr <Action>(RenameElement)
nmap <leader>rv <Action>(ExtractVariable)
nmap <leader>rm <Action>(ExtractMethod)
nmap <leader>ri <Action>(Inline)

" code ('c'ode)
nmap <leader>cr <Action>(ReformatCode)
nmap <leader>co <Action>(OptimizeImports)
nmap <leader>ca <Action>(ShowIntentionActions)


" ** 3. Run / Debug **
" build / run ('b'uild or 'r'un)
nmap <leader>bb <Action>(BuildProject)
nmap <leader>br <Action>(Run)
nmap <leader>bd <Action>(Debug)
nmap <leader>bt <Action>(RunContextConfiguration)


" ** 4. Window / UI operations **
" window ('w'indow)
nmap <leader>wt <Action>(ActivateTerminalToolWindow)
nmap <leader>wc <Action>(HideAllWindows)
nmap <leader>wp <Action>(OpenProjectWindows)


" ** 5. VCS **
" VCS ('v'cs)
nmap <leader>vs <Action>(Vcs.ShowMessageHistory)
nmap <leader>vc <Action>(CheckinProject)
nmap <leader>vp <Action>(Vcs.Push)
nmap <leader>vg <Action>(Vcs.Operations)

" ** 6. Others **
cnoremap <C-p> <Up>
cnoremap <C-n> <Down>
